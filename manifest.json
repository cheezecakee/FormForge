{
    "name": "Form Forge",
    "description": "Easy job application form filler",
    "version": "1.0.0",
    "manifest_version": 3,
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            }
        }
    },
    "icons": {
        "16": "logo/logo_16.png",
        "32": "logo/logo_32.png",
        "48": "logo/logo_48.png",
        "128": "logo/logo_128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "logo/logo_16.png",
            "32": "logo/logo_32.png",
            "48": "logo/logo_48.png",
            "128": "logo/logo_128.png"
        }
    },
    "background": {
        "service_worker": "dist/background.js"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "storage"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "panel/*",
                "global.css",
                "logo/*",
                "profile/*",
                "assets/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "host_permissions": [
        "https://*.greenhouse.io/*",
        "https://*.workday.com/*",
        "https://*.lever.co/*",
        "https://www.linkedin.com/jobs/*",
        "https://*.bamboohr.com/*",
        "https://*.ashbyhq.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://*.greenhouse.io/*",
                "https://*.workday.com/*",
                "https://*.lever.co/*",
                "https://www.linkedin.com/jobs/*",
                "https://*.bamboohr.com/*",
                "https://*.ashbyhq.com/*"
            ],
            "js": [
                "dist/content-script.js"
            ]
        }
    ]
}
