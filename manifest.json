{
    "name": "Form Forge",
    "description": "Easy job application form autofiller",
    "version": "1.0",
    "manifest_version": 3,
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+B",
                "mac": "Command+B"
            }
        }
    },
    "icons": {
        "16": "logo/logo_16.png",
        "32": "logo/logo_32.png",
        "48": "logo/logo_48.png",
        "128": "logo/logo_128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "logo/logo_16.png",
            "32": "logo/logo_32.png",
            "48": "logo/logo_48.png",
            "128": "logo/logo_128.png"
        }
    },
    "background": {
        "service_worker": "dist/background.js"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "storage",
        "sidePanel"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "panel/*",
                "global.css",
                "logo/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "host_permissions": [
        "https://*.workday.com/*",
        "https://*.linkedin.com/*",
        "https://*.greenhouse.io/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://*.workday.com/*",
                "https://*.linkedin.com/*",
                "https://*.greenhouse.io/*",
                "https://*.bamboohr.com/*",
                "https://*.fullstack.com/*"
            ],
            "js": [
                "dist/content-script.js"
            ]
        }
    ]
}
